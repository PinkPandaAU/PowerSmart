<section class="main-index page-width">
  <h1>{{ section.settings.heading }}</h1>
  {%- if section.settings.subheading != blank -%}
    <p>{{ section.settings.subheading }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Homepage",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to PowerSmart"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Smart power solutions for every home and business."
    }
  ],
  "presets": [
    {
      "name": "Homepage"
    }
  ]
}
{% endschema %}
