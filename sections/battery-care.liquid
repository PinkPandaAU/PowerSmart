{%- if section.settings.icon != blank or section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank or section.settings.image != blank or section.settings.image_mobile != blank or section.settings.image_large != blank -%}
<section class="panel" id="{{ section.settings.section_id }}">
    <div class="container">
        <div class="panel__wrapper">
            {%- if section.settings.icon != blank or section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank -%}
                <div class="panel__text fade-in-wrapper">
                    {%- if section.settings.icon != blank -%}
                        <div class="panel__icon">
                            <img src="{{ section.settings.icon | image_url }}" alt="{{ section.settings.icon | escape }}">
                        </div>
                    {%- endif -%}

                    {%- if section.settings.heading != blank -%}
                        <h2>{{ section.settings.heading }}</h2>
                    {%- endif -%}

                    {%- if section.settings.text != blank -%}
                        {{ section.settings.text }}
                    {%- endif -%}

                    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
                        <a href="{{ section.settings.button_link }}" class="button button--primary-outlined" data-toggle="modal">
                            <span class="button__wrapper">
                                <span class="button__circle">
                                    <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-white"></use></svg>
                                </span>
                                <span class="button__text">
                                    <span>{{ section.settings.button_label }}</span>
                                    <span class="duplicate">{{ section.settings.button_label }}</span>
                                </span>
                                <span class="button__circle">
                                    <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-white"></use></svg>
                                </span>
                            </span>
                        </a>
                    {%- endif -%}
                </div>
            {%- endif -%}

            {%- if section.settings.image_large != blank or section.settings.image != blank or section.settings.image_mobile != blank -%}
                <div class="panel__visual">
                    {%- if section.settings.image_large != blank -%}
                        <a class="gallery" href="{{ section.settings.image_large | image_url }}" data-pswp-width="1792" data-pswp-height="1000">
                            {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}    
                                <picture>
                                    {%- if section.settings.image_mobile != blank -%}
                                        <source srcset="{{ section.settings.image_mobile | image_url }}" media="(max-width: 767px)">
                                    {%- endif -%}
                                    {%- if section.settings.image != blank -%}
                                        <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.image_alt | escape }}">
                                    {%- endif -%}
                                </picture>
                            {%- endif -%}
                        </a>
                    {%- else -%}
                        {%- if section.settings.image != blank or section.settings.image_mobile != blank -%}    
                            <picture>
                                {%- if section.settings.image_mobile != blank -%}
                                    <source srcset="{{ section.settings.image_mobile | image_url }}" media="(max-width: 767px)">
                                {%- endif -%}
                                {%- if section.settings.image != blank -%}
                                    <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.image_alt | escape }}">
                                {%- endif -%}
                            </picture>
                        {%- endif -%}
                    {%- endif -%}
                </div>
            {%- endif -%}
        </div>
    </div>
</section>  
{%- endif -%}

{% schema %}
{
  "name": "Battery Care",
  "tag": "div",
  "settings": [
    {
        "type": "text",
        "id": "section_id",
        "label": "Section ID",
        "default": "batteryCare"
    },
    { "type": "image_picker", "id": "icon", "label": "Icon" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Understanding your <span>battery’s</span> <span>lifespan</span>" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Just like smoke alarm batteries, lithium batteries should be replaced regularly.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get Replacement Batteries" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image (mobile)" },
    { "type": "image_picker", "id": "image", "label": "Image (default)" },
    { "type": "image_picker", "id": "image_large", "label": "Image (lightbox)" }
  ],
  "presets": [
    { 
        "name": "Battery Care"
    }
  ]
}
{% endschema %}
