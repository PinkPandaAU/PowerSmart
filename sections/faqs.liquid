{%- if section.settings.subtitle != blank or section.settings.heading_text != blank or section.settings.button_label != blank or section.blocks.size > 0 -%}
    <div class="container container--sm">
        {%- if section.settings.subtitle != blank or section.settings.heading_text != blank or section.settings.button_label != blank -%}
            <div class="faqs__header fade-in-wrapper">
                {%- if section.settings.subtitle != blank -%}
                    <div class="subtitle">{{ section.settings.subtitle }}</div>
                {%- endif -%}

                {%- if section.settings.heading_text != blank -%}
                    <h2>{{ section.settings.heading_text }}</h2>
                {%- endif -%}

                {%- if section.settings.button_label != blank -%}
                    <a data-toggle="modal" href="{{ section.settings.button_link }}" class="button button--primary-outlined">
                        <span class="button__wrapper">
                            <span class="button__circle">
                                <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-white"></use></svg>
                            </span>
                            <span class="button__text">
                                <span>{{ section.settings.button_label }}</span>
                                <span class="duplicate">{{ section.settings.button_label }}</span>
                            </span>
                            <span class="button__circle">
                                <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-white"></use></svg>
                            </span>
                        </span>
                    </a>
                {%- endif -%}
            </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
            {%- assign total_items = section.blocks.size -%}
            {%- assign half_items = total_items | divided_by: 2 | ceil -%}
            <div class="accordion fade-in-wrapper">
                <div class="accordion__col">
                    {%- for block in section.blocks -%}
                        {%- if forloop.index0 <= half_items -%}
                            {%- if block.settings.question != blank and block.settings.answer != blank -%}
                                <div class="accordion__item">
                                    <button type="button" class="accordion__item-button">{{ block.settings.question }}</button>
                                    <div class="accordion__item-body">
                                        <div class="accordion__item-inner">
                                            <p>{{ block.settings.answer }}</p>
                                        </div>
                                    </div>
                                </div>
                            {%- endif -%}
                        {%- endif -%}
                    {%- endfor -%}
                </div>

            <div class="accordion__col">
                {%- for block in section.blocks -%}
                    {%- if forloop.index0 > half_items -%}
                        {%- if block.settings.question != blank and block.settings.answer != blank -%}
                            <div class="accordion__item">
                                <button type="button" class="accordion__item-button">{{ block.settings.question }}</button>
                                <div class="accordion__item-body">
                                    <div class="accordion__item-inner">
                                        <p>{{ block.settings.answer }}</p>
                                    </div>
                                </div>
                            </div>
                        {%- endif -%}
                    {%- endif -%}
                {%- endfor -%}
            </div>
            </div>
        {%- endif -%}
    </div>
{%- endif -%}

