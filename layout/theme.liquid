            (function(k) {
                let s=document.createElement('script');s.defer=true;
                s.src="https://cdn.feedbucket.app/assets/feedbucket.js";
                s.dataset.feedbucket=k;document.head.appendChild(s);
            })('UHWo2lassVDRyRiqp61F')
        </script>-->

        {{content_for_header}}
        {% if template == 'index' %}
            {{ 'styles-start.css' | asset_url | stylesheet_tag }}
            {{ 'style.css' | asset_url | stylesheet_tag }}
        {% else %}
            {{ 'style.css' | asset_url | stylesheet_tag }}
        {% endif %}
    </head>

    <body>
        <div class="global-wrapper" >
            {% section 'header' %}
            
            <main class="content">
                {{ content_for_layout }}
            </main>

            {% section 'footer' %}
        </div>

        <div id="modalVideo" class="modal">
        <div class="modal__backdrop"></div>

        <button data-modal-close class="modal__close" aria-label="Close">
            <svg width="12" height="12"><use xlink:href="{{ 'sprite.svg' | asset_url }}#close"></use></svg>
        </button>

        <div class="modal__wrapper">
            <div class="modal__content">
            <div class="modal__body">
                <div class="video-wrapper">
                <iframe src="" referrerpolicy="strict-origin-when-cross-origin" allow="autoplay; encrypted-media; fullscreen" allowfullscreen> </iframe>
                </div>
            </div>
            </div>
        </div>
        </div>

        {% comment %} BUY NOW MODAL {% endcomment %}
        {%- if settings.buy_now_modal_subtitle != blank or settings.buy_now_modal_heading_text != blank or settings.buy_now_modal_offer_title != blank or settings.buy_now_modal_offer_description != blank or settings.buy_now_modal_product != blank -%}
            <div id="buy-now" class="modal">
                <div class="modal__backdrop"></div>
                <div class="modal__wrapper">
                    <div class="modal__content">
                        <button data-modal-close class="modal__close" aria-label="Close">
                            <svg width="12" height="12"><use xlink:href="{{ 'sprite.svg' | asset_url }}#close"></use></svg>
                        </button>

                        <div class="modal__body">
                            <div class="products">
                                <div class="products__wrapper">

                                    {%- if settings.buy_now_modal_subtitle != blank or settings.buy_now_modal_heading_text != blank or settings.buy_now_modal_offer_title != blank or settings.buy_now_modal_offer_description != blank -%}
                                        <div class="products__col fade-in-wrapper">
                                            {%- if settings.buy_now_modal_subtitle != blank -%}
                                                <div class="subtitle">{{ settings.buy_now_modal_subtitle }}</div>
                                            {%- endif -%}
                                            
                                            {%- if settings.buy_now_modal_heading_text != blank -%}
                                                <h3>{{ settings.buy_now_modal_heading_text }}</h3>
                                            {%- endif -%}

                                            {%- if settings.buy_now_modal_offer_title != blank or settings.buy_now_modal_offer_description != blank -%}
                                                <div class="cp-offer">
                                                    {%- if settings.buy_now_modal_offer_title != blank -%}
                                                        <div class="cp-offer__title">
                                                            <svg width="24" height="24"><use xlink:href="{{ 'sprite.svg' | asset_url }}#badge"></use></svg>
                                                            {{ settings.buy_now_modal_offer_title }}
                                                        </div>
                                                    {%- endif -%}
                                                    
                                                    {%- if settings.buy_now_modal_offer_description != blank -%}
                                                        <p>{{ settings.buy_now_modal_offer_description }}</p>
                                                    {%- endif -%}
                                                </div>
                                            {%- endif -%}
                                        </div>
                                    {%- endif -%}

                                    <div class="products__col">
                                        <div class="products__grid">
                                            {%- if settings.buy_now_modal_product != blank -%}
                                                {%- for product in settings.buy_now_modal_product -%}
                                                    {% include 'product-card', product: product %}
                                                {%- endfor -%}
                                            {% else -%}
                                                {% for product in collections.all.products limit: 2 %}
                                                    {% include 'product-card', product: product %}
                                                {%- endfor -%}
                                            {%- endif -%}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {%- endif -%}

        {% comment %} ADD TO CART MODAL {% endcomment %}
        <div id="modalCart" class="modal cart-modal">
            <div class="modal__backdrop"></div>

            <button data-modal-close class="modal__close" aria-label="Close">
                <svg width="12" height="12"><use xlink:href="{{ 'sprite.svg' | asset_url }}#close"></use></svg>
            </button>

            <div class="modal__wrapper">
                <div class="modal__content">

                    {%- if settings.cart_modal_title != blank -%}
                        <h3>{{ settings.cart_modal_title }}</h3>
                    {%- endif -%}

                    {% comment %} Empty cart content {% endcomment %}
                    {%- if settings.cart_modal_empty_cart_message != blank or settings.cart_modal_shop_btn_text != blank  -%}
                        <div class="cart-empty">
                            <h4 class="cart-empty__message">{{ settings.cart_modal_empty_cart_message }}</h4>

                            <a href="{{ routes.all_products_collection_url }}" class="button button--primary">
                                <span class="button__wrapper">
                                    <span class="button__circle">
                                        <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-navy"></use></svg>
                                    </span>
                                    <span class="button__text">
                                        <span>{{ settings.cart_modal_shop_btn_text }}</span>
                                        <span class="duplicate">{{ settings.cart_modal_shop_btn_text }}</span>
                                    </span>
                                    <span class="button__circle">
                                        <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-blue"></use></svg>
                                    </span>
                                </span>
                            </a>
                        </div>
                    {%- endif -%}

                    <!-- Container for all cart items -->
                    <div class="cart-items-container">
                        <div class="cart-item__loader-container">
                            <span class="cart-item__loader">
                                <svg width="60" height="60" viewBox="0 0 38 38">
                                    <g transform="translate(19 19)">
                                        <g transform="rotate(0)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.125"><animate attributeName="opacity" from="0.125" to="0.125" dur="1.2s" begin="0s" repeatCount="indefinite" keyTimes="0;1" values="1;0.125"></animate></circle>
                                        </g>
                                        <g transform="rotate(45)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.25"><animate attributeName="opacity" from="0.25" to="0.25" dur="1.2s" begin="0.15s" repeatCount="indefinite" keyTimes="0;1" values="1;0.25"></animate></circle>
                                        </g>
                                        <g transform="rotate(90)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.375"><animate attributeName="opacity" from="0.375" to="0.375" dur="1.2s" begin="0.3s" repeatCount="indefinite" keyTimes="0;1" values="1;0.375"></animate></circle>
                                        </g>
                                        <g transform="rotate(135)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.5"><animate attributeName="opacity" from="0.5" to="0.5" dur="1.2s" begin="0.45s" repeatCount="indefinite" keyTimes="0;1" values="1;0.5"></animate></circle>
                                        </g>
                                        <g transform="rotate(180)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.625"><animate attributeName="opacity" from="0.625" to="0.625" dur="1.2s" begin="0.6s" repeatCount="indefinite" keyTimes="0;1" values="1;0.625"></animate></circle>
                                        </g>
                                        <g transform="rotate(225)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.75"><animate attributeName="opacity" from="0.75" to="0.75" dur="1.2s" begin="0.75s" repeatCount="indefinite" keyTimes="0;1" values="1;0.75"></animate></circle>
                                        </g>
                                        <g transform="rotate(270)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="0.875"><animate attributeName="opacity" from="0.875" to="0.875" dur="1.2s" begin="0.9s" repeatCount="indefinite" keyTimes="0;1" values="1;0.875"></animate></circle>
                                        </g>
                                        <g transform="rotate(315)">
                                            <circle cx="0" cy="12" r="3" fill="#00aeef" opacity="1"><animate attributeName="opacity" from="1" to="1" dur="1.2s" begin="1.05s" repeatCount="indefinite" keyTimes="0;1" values="1;1"></animate></circle>
                                        </g>
                                    </g>
                                </svg>
                            </span>
                        </div>
                        <!-- Items will be loaded here by JavaScript -->
                    </div>

                    <div class="cart-total"><strong>Subtotal:</strong> $0.00</div>

                    {%- if settings.cart_modal_btn_title != blank -%}
                        <a href="/checkout" class="button button--primary btn--checkout">
                            <span class="button__wrapper">
                                <span class="button__circle">
                                    <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-navy"></use></svg>
                                </span>
                                <span class="button__text">
                                    <span>{{ settings.cart_modal_btn_title }}</span>
                                    <span class="duplicate">{{ settings.cart_modal_btn_title }}</span>
                                </span>
                                <span class="button__circle">
                                    <svg width="13" height="9"><use xlink:href="{{ 'sprite.svg' | asset_url }}#arr-blue"></use></svg>
                                </span>
                            </span>
                        </a>
                    {%- endif -%}
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="{{ 'plugins.js' | asset_url }}" defer></script>
        <script src="{{ 'theme.js' | asset_url }}" defer></script>

    </body>
</html>