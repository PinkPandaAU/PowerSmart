<section class="block-login">
    <div class="container fade-in-wrapper">
        <div class="login-wrapper">
            <h1>{{ section.settings.title }}</h1>
            <p>{{ section.settings.description }}</p>
            
            <form method="post" action="/account/login" class="login-form">
                <div class="form-group">
                    <label for="email">{{ 'customer.login.email' | t }}</label>
                    <input type="email" name="customer[email]" id="email" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="password">{{ 'customer.login.password' | t }}</label>
                    <input type="password" name="customer[password]" id="password" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="remember">
                        <input type="checkbox" name="customer[remember]" id="remember">
                        {{ 'customer.login.remember' | t }}
                    </label>
                </div>
                
                <button type="submit" class="button button--primary">{{ section.settings.button_text }}</button>
            </form>
            
            <div class="login-links">
                <a href="/account/register">{{ section.settings.register_link_text }}</a>
                <a href="/account/recover">{{ section.settings.forgot_password_text }}</a>
            </div>
        </div>
    </div>
</section>
