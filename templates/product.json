          "type": "faq_item",
          "settings": {
            "question": "Why should I replace my roller shutter battery?",
            "answer": "Lithium batteries have a natural lifespan of 5 - 6 years. Over time, their performance declines and, in some cases, they may become unsafe. Replacing your battery ensures your system continues to operate safely and reliably."
          }
        },
        "faq_item_JtEaiT": {
          "type": "faq_item",
          "settings": {
            "question": "Is there a problem with my current battery?",
            "answer": "Not necessarily. If your battery is less than three years old and performing well, you may not need a replacement yet. However, if it’s older, or you notice signs of decline, replacement is recommended."
          }
        },
        "faq_item_Eb9Myx": {
          "type": "faq_item",
          "settings": {
            "question": "What are the warning signs of a battery that needs replacement?",
            "answer": "Stop using your battery if:<ul><li>It loses charge quickly.</li><li>It takes longer to charge.</li><li>It heats up excessively while charging.</li><li>It has started swelling.</li><li>It has been dropped or damaged.</li></ul>"
          }
        },
        "faq_item_R9RrRt": {
          "type": "faq_item",
          "settings": {
            "question": "Is this a recall?",
            "answer": "No. It is a proactive program from CW Products to encourage regular battery care and replacement, similar to checking your smoke alarm batteries each year."
          }
        },
        "faq_item_xiLbXb": {
          "type": "faq_item",
          "settings": {
            "question": "How often should I replace my roller shutter battery?",
            "answer": "For peace of mind, lithium batteries should be replaced every 5 - 6 years."
          }
        },
        "faq_item_XdYEP3": {
          "type": "faq_item",
          "settings": {
            "question": "What if my battery is less than five years old?",
            "answer": "You may not need to replace it right away. Continue to use your battery but keep an eye on its performance. If you notice any of the warning signs, replace it immediately."
