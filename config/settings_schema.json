[
  {
    "name": "theme_info",
    "theme_name": "PowerSmart",
    "theme_version": "1.0.0",
    "theme_author": "PowerSmart",
    "theme_documentation_url": "https://powersmart.example.com",
    "theme_support_url": "https://powersmart.example.com/support"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Will be scaled to 32 x 32px"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary",
        "default": "#0a6cff"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#121212"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font",
        "default": "assistant_n7"
      }
    ]
  },
  {
    "name": "Buy now model",
    "settings": [
      {
        "type": "text",
        "id": "buy_now_modal_subtitle",
        "label": "Subtitle",
        "default": "Buy replacement batteries"
      },
      {
        "type": "textarea",
        "id": "buy_now_modal_heading_text",
        "label": "Heading",
        "default": "Get your <span>replacement</span> <span>batteries</span>"
      },
      {
        "type": "text",
        "id": "buy_now_modal_offer_title",
        "label": "Offer Title",
        "default": "Limited time special offer"
      },
      {
        "type": "textarea",
        "id": "buy_now_modal_offer_description",
        "label": "Offer Description",
        "default": "Use the unique code provided by your retailer at checkout for an exclusive discount."
      },
      {
        "type": "product_list",
        "id": "buy_now_modal_product",
        "label": "Select Products",
        "limit": 2
      }
    ]
  },
  {
    "name": "Cart model",
    "settings": [
      {
        "type": "textarea",
        "id": "cart_modal_title",
        "label": "Heading",
        "default": "Your <span>cart</span>"
      },
      {
        "type": "text",
        "id": "cart_modal_empty_cart_message",
        "label": "Empty cart message",
        "default": "Your cart is empty."
      },
      {
        "type": "text",
        "id": "cart_modal_shop_btn_text",
        "label": "Shop Button Text",
        "default": "Continue shopping"
      },
      {
        "type": "text",
        "id": "cart_modal_btn_title",
        "label": "Checkout Button Text",
        "default": "Checkout"
      }
    ]
  }
]
